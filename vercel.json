{
    "buildCommand": "npm run build:web",
    "outputDirectory": "dist",
    "framework": null,
    "rewrites": [
        {
            "source": "/api/notion/:match*",
            "destination": "/api/proxy"
        },
        {
            "source": "/api/gemini/:match*",
            "destination": "/api/gemini"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "redirects": [
        {
            "source": "/atlas/(.*)",
            "destination": "https://ai-notion-task.vercel.app/$1",
            "permanent": false
        },
        {
            "source": "/atlas",
            "destination": "https://ai-notion-task.vercel.app",
            "permanent": false
        }
    ]
}
